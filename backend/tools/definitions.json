  {
    "name": "add_transaction",
    "description": "Add a new income (inc) or expense (exp) transaction with description and amount.",
    "handler": "transactions",
    "tiers": ["sigla", "unlad"],
    "parameters": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["inc", "exp"], "description": "inc = money in, exp = money out" },
        "desc": { "type": "string", "description": "Short description of the transaction" },
        "amt": { "type": "number", "description": "Amount in Philippine Peso (₱)" },
        "cat": { "type": "string", "description": "Category (Supplies, Labor, Utilities, Rent, Transportation, Marketing, Miscellaneous)" }
      },
      "required": ["type", "desc", "amt"]
    }
  },
  {
    "name": "delete_transaction",
    "description": "Delete a transaction by its ID number.",
    "handler": "transactions",
    "tiers": ["sigla", "unlad"],
    "parameters": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "description": "The ID of the transaction to delete" }
      },
      "required": ["id"]
    }
  },
  {
    "name": "add_inventory_item",
    "description": "Add a new inventory item with name, quantity, unit, and optional minimum stock threshold.",
    "handler": "inventory",
    "tiers": ["simula", "sigla", "unlad"],
    "parameters": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Item name" },
        "qty": { "type": "integer", "description": "Current stock quantity" },
        "unit": { "type": "string", "description": "Unit of measurement (pcs, kg, box, pack, bottle, sachet, liter, pair)" },
        "min_threshold": { "type": "integer", "description": "Minimum stock level before alert (default 0)" }
      },
      "required": ["name", "qty", "unit"]
    }
  },
  {
    "name": "set_stock_threshold",
    "description": "Set or update the minimum stock threshold for an inventory item to trigger low-stock alerts.",
    "handler": "inventory",
    "tiers": ["sigla", "unlad"],
    "parameters": {
      "type": "object",
      "properties": {
        "item_id": { "type": "integer", "description": "The ID of the inventory item" },
        "min_threshold": { "type": "integer", "description": "New minimum stock level" }
      },
      "required": ["item_id", "min_threshold"]
    }
  },
  {
    "name": "update_inventory_item",
