[
  {
    "name": "calculate",
    "description": "Perform arithmetic calculations (add, subtract, multiply, divide, percentage). Use this for any math instead of guessing numbers.",
    "handler": "math",
    "tiers": ["simula", "sigla", "unlad"],
    "parameters": {
      "type": "object",
      "properties": {
        "expression": {
          "type": "string",
          "description": "A mathematical expression using +, -, *, /, %, and parentheses. E.g. (4500 + 1520 + 18000 + 500) - (820 + 380 + 200)"
        }
      },
      "required": ["expression"]
    }
  },
  {
    "name": "render_table",
    "description": "Present data in a formatted table. Use this instead of using pipes, dashes, or any formatting characters.",
    "handler": "table",
    "tiers": ["simula", "sigla", "unlad"],
    "parameters": {
      "type": "object",
      "properties": {
        "columns": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Column headers, e.g. ['Item', 'Quantity', 'Price']"
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {"type": "string"}
          },
          "description": "Data rows, e.g. [['Rice', '50 kg', '₱2,500'], ['Oil', '12 L', '₱1,200']]"
        }
      },
      "required": ["columns", "rows"]
    }
  },
  {
