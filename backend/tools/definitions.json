    "tiers": ["simula", "sigla", "unlad"],
    "parameters": {
      "type": "object",
      "properties": {
        "item_id": { "type": "integer", "description": "The ID of the inventory item to update" },
        "name": { "type": "string", "description": "New item name (optional)" },
        "qty": { "type": "integer", "description": "New quantity (optional)" },
        "unit": { "type": "string", "description": "New unit (optional, e.g. pcs, kg, box)" }
      },
      "required": ["item_id"]
    }
  },
  {
    "name": "remove_inventory_item",
    "description": "Remove an inventory item by its ID.",
    "handler": "inventory",
    "tiers": ["simula", "sigla", "unlad"],
