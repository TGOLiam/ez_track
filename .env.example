# EzTrack — LLM API Configuration
# Compatible with any OpenAI-compatible endpoint.

OPENAI_API_KEY=sk-your-api-key-here
LLM_API_URL=https://api.deepseek.com/chat/completions
LLM_MODEL=deepseek-v4-pro
# LLM_REASONING_EFFORT=high
# LLM_EXTRA_BODY={"thinking":{"type":"enabled"}}

# Shared API key for frontend-to-backend auth.
# Must match VITE_API_KEY in frontend .env.
API_KEY=ez_shared_dev_key_change_in_prod
